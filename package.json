{
  "name": "@ludicon/spark.js",
  "version": "0.1.4",
  "description": "Real-Time GPU Texture Codecs for the Web",
  "main": "dist/spark.esm.js",
  "module": "dist/spark.esm.js",
  "type": "module",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/spark.esm.js",
      "types": "./src/index.d.ts"
    },
    "./three": {
      "import": "./src/three.js",
      "types": "./src/three.d.ts"
    },
    "./three-gltf": {
      "import": "./src/three-gltf.js",
      "types": "./src/three-gltf.d.ts"
    }
  },
  "files": [
    "dist",
    "src/three.js",
    "src/three.d.ts",
    "src/three-gltf.js",
    "src/three-gltf.d.ts",
    "src/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "build:examples": "vite build --config vite.config.examples.js",
    "build:examples:local": "BASE_PATH=/ vite build --config vite.config.examples.js",
    "watch": "vite build --watch",
    "serve": "vite --host --open /examples/index.html",
    "dev": "run-p watch serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\"",
    "validate-shaders": "for shader in src/shaders/*.wgsl; do echo \"Validating $shader...\"; tint \"$shader\" --validate > /dev/null || exit 1; done && echo \"All shaders validated successfully!\"",
    "analyze-bundle": "node scripts/analyze-bundle-size.js",
    "prepublishOnly": "npm run validate-shaders && npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "gpu",
    "webgpu",
    "spark",
    "texture",
    "compression",
    "transcoding",
    "astc",
    "bc1",
    "bc3",
    "bc4",
    "bc5",
    "bc7",
    "etc2",
    "eac",
    "graphics",
    "wgsl",
    "image",
    "codec",
    "real-time"
  ],
  "author": "Ludicon LLC (https://ludicon.com/)",
  "license": "See LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludicon/spark.js.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "3d-tiles-renderer": "^0.4.24",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "rollup-plugin-summary": "^3.0.1",
    "three": "^0.184.0",
    "vite": "^7.0.0"
  },
  "peerDependencies": {
    "three": ">=0.182.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "directories": {
    "example": "examples"
  },
  "bugs": {
    "url": "https://github.com/ludicon/spark.js/issues"
  },
  "homepage": "https://ludicon.com/sparkjs"
}
